{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/service-city-b-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://*:5002",
  "ServiceName": "ServiceCityB",
  "CityCode": "CITYB",
  "Nacos": {
    "ServerAddresses": [ "http://localhost:8848" ],
    "Namespace": "dev",
    "GroupName": "DEFAULT_GROUP",
    "UserName": "nacos",
    "Password": "nacos",
    "ListenInterval": 10000,
    "ServiceName": "ServiceCityB",
    "ClusterName": "DEFAULT",
    "Port": 5002,
    "Weight": 100,
    "RegisterEnabled": true,
    "InstanceEnabled": true,
    "Ephemeral": true,
    "ConfigUseRpc": false,
    "NamingUseRpc": false,
    "Listeners": [
      {
        "Optional": true,
        "DataId": "medical-insurance-common.json",
        "Group": "DEFAULT_GROUP"
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=medical_insurance;Uid=root;Pwd=12345678;CharSet=utf8mb4;"
  },
  "Polly": {
    "Timeout": 10,
    "RetryCount": 3,
    "CircuitBreakerExceptionsAllowed": 5,
    "CircuitBreakerDuration": 30
  },
  "Heartbeat": {
    "IntervalSeconds": 10
  }
}